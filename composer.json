{
    "name": "anyauction/anyauction",
    "description": "AnyAuction — an online auction marketplace built with PHP Slim, Twig, and MariaDB.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "cloudinary/cloudinary_php": "^2.13",
        "php-di/php-di": "^7.0",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.12",
        "slim/twig-view": "^3.4",
        "stripe/stripe-php": "^14.0",
        "twilio/sdk": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public"
    },
    "config": {
        "sort-packages": true
    }
}
