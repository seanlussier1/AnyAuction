{% extends 'layout.twig' %}
{% block title %}{{ 'watchlist.page.title'|t }} — AnyAuction{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-heart-fill text-danger fs-4"></i>
        <h1 class="h3 mb-0">{{ 'watchlist.page.title'|t }}</h1>
        <span class="text-muted-aa">({{ auctions|length }})</span>
    </div>

    {% if auctions|length == 0 %}
        <div class="text-center py-5">
            <i class="bi bi-heart fs-1 text-muted-aa opacity-25 d-block mb-3"></i>
            <h3 class="h5 text-muted-aa">{{ 'watchlist.empty.heading'|t }}</h3>
            <p class="small text-muted-aa">{{ 'watchlist.empty.body'|t }}</p>
            <a href="/browse" class="btn btn-primary mt-2">{{ 'profile.bids.browse'|t }}</a>
        </div>
    {% else %}
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
            {% for auction in auctions %}
                <div class="col">
                    {% include 'partials/auction_card.twig' with { auction: auction } only %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
