{% extends 'layout.twig' %}
{% block title %}{{ 'report.title'|t }} — AnyAuction{% endblock %}

{% block content %}
<div class="container py-4" style="max-width: 40rem;">
    <nav aria-label="breadcrumb" class="small text-muted-aa">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/auction/{{ auction.item_id }}" class="text-decoration-none text-muted-aa">{{ auction.title }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'report.breadcrumb'|t }}</li>
        </ol>
    </nav>

    <h1 class="h3 mb-3">{{ 'report.title'|t }}</h1>
    <p class="text-muted-aa">{{ 'report.intro_html'|t({ title: auction.title })|raw }}</p>

    <form action="/report/listing/{{ auction.item_id }}" method="post" class="d-flex flex-column gap-3">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">

        <div>
            <label class="form-label">{{ 'report.reason'|t }}</label>
            <select name="reason" class="form-select" required>
                <option value="" {% if not old.reason %}selected{% endif %} disabled>{{ 'report.reason.placeholder'|t }}</option>
                {% for value, label in reasons %}
                    <option value="{{ value }}" {% if old.reason == value %}selected{% endif %}>{{ ('report.reason.' ~ value)|t }}</option>
                {% endfor %}
            </select>
            {% if errors.reason %}<div class="text-danger small mt-1">{{ errors.reason }}</div>{% endif %}
        </div>

        <div>
            <label class="form-label">{{ 'report.details'|t }}</label>
            <textarea name="details" class="form-control" rows="6" minlength="10" maxlength="2000"
                      placeholder="{{ 'report.details.placeholder'|t }}" required>{{ old.details|default('') }}</textarea>
            <div class="form-text">{{ 'report.details.help'|t }}</div>
            {% if errors.details %}<div class="text-danger small mt-1">{{ errors.details }}</div>{% endif %}
        </div>

        <div class="d-flex gap-2">
            <a href="/auction/{{ auction.item_id }}" class="btn btn-outline-secondary">{{ 'btn.cancel'|t }}</a>
            <button type="submit" class="btn btn-danger">{{ 'report.submit'|t }}</button>
        </div>
    </form>
</div>
{% endblock %}
