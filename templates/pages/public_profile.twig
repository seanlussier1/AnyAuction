{% extends 'layout.twig' %}
{% block title %}{{ profile_user.first_name }} {{ profile_user.last_name }} — AnyAuction{% endblock %}

{% block content %}
<div class="container py-4">

    <div class="p-4 p-md-5 rounded-xl text-white mb-4"
         style="background: linear-gradient(135deg, #030213 0%, #1a1a2e 60%, #242443 100%);">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-3">
                {% if profile_user.profile_picture %}
                    <img src="{{ profile_user.profile_picture }}" class="rounded-circle" width="64" height="64" alt="">
                {% else %}
                    <span class="aa-brand-badge d-inline-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                        <i class="bi bi-person fs-3"></i>
                    </span>
                {% endif %}
                <div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <h1 class="h3 text-white mb-0">{{ profile_user.first_name }} {{ profile_user.last_name }}</h1>
                        {% if profile_user.is_verified %}
                            <i class="bi bi-patch-check-fill" style="color:#3b82f6;"></i>
                        {% endif %}
                        <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle text-capitalize">{{ profile_user.role }}</span>
                    </div>
                    <div class="small text-white-50">@{{ profile_user.username }}</div>
                    <div class="small text-white-50 opacity-75">Member since {{ profile_user.created_at|date('F Y') }}</div>
                </div>
            </div>
        </div>

        <div class="row row-cols-2 row-cols-md-4 g-3 mt-3">
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.rating }}</div>
                <div class="small text-white-50"><i class="bi bi-star-fill"></i> Rating</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.reviews }}</div>
                <div class="small text-white-50">Reviews</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ listings|length }}</div>
                <div class="small text-white-50">Listings</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <h2 class="h5 mb-3">Reviews</h2>
            {% include 'partials/reviews_panel.twig' with { stats: stats, reviews: reviews } only %}
        </div>

        <div class="col-lg-5">
            <h2 class="h5 mb-3">Listings by {{ profile_user.first_name }}</h2>
            {% if listings|length == 0 %}
                <p class="text-muted-aa small">No listings yet.</p>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 g-3">
                    {% for auction in listings %}
                        <div class="col">{% include 'partials/auction_card.twig' with { auction: auction } only %}</div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
