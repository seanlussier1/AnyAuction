{% extends 'layout.twig' %}
{% block title %}{{ profile_user.first_name }} {{ profile_user.last_name }} — AnyAuction{% endblock %}

{% block content %}
<div class="container py-4">

    <div class="p-4 p-md-5 rounded-xl text-white mb-4"
         style="background: linear-gradient(135deg, #030213 0%, #1a1a2e 60%, #242443 100%);">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-3">
                {% if profile_user.profile_picture %}
                    <img src="{{ profile_user.profile_picture }}" class="rounded-circle" width="64" height="64" alt="">
                {% else %}
                    <span class="aa-brand-badge d-inline-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                        <i class="bi bi-person fs-3"></i>
                    </span>
                {% endif %}
                <div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <h1 class="h3 text-white mb-0">{{ profile_user.first_name }} {{ profile_user.last_name }}</h1>
                        {% if profile_user.is_verified %}
                            <i class="bi bi-patch-check-fill" style="color:#3b82f6;"></i>
                        {% endif %}
                        <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle text-capitalize">{{ profile_user.role }}</span>
                    </div>
                    <div class="small text-white-50">@{{ profile_user.username }}</div>
                    <div class="small text-white-50 opacity-75">{{ 'profile.member_since'|t({ date: profile_user.created_at|date('F Y') }) }}</div>
                </div>
            </div>
        </div>

        <div class="row row-cols-2 row-cols-md-4 g-3 mt-3">
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.rating }}</div>
                <div class="small text-white-50"><i class="bi bi-star-fill"></i> {{ 'profile.stat.rating'|t }}</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.reviews }}</div>
                <div class="small text-white-50">{{ 'profile.stat.reviews'|t }}</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ listings|length }}</div>
                <div class="small text-white-50">{{ 'public_profile.stat.listings'|t }}</div>
            </div>
        </div>
    </div>

    {% if rateable_orders|length > 0 %}
        <div class="p-3 mb-4 rounded-lg-aa border border-warning-subtle bg-warning-subtle">
            <h2 class="h6 mb-2"><i class="bi bi-star me-1 text-warning"></i>{{ 'public_profile.rate.heading'|t({ name: profile_user.first_name }) }}</h2>
            <p class="small text-muted-aa mb-3">
                {% if rateable_orders|length == 1 %}
                    {{ 'public_profile.rate.intro_one'|t({ count: rateable_orders|length }) }}
                {% else %}
                    {{ 'public_profile.rate.intro_many'|t({ count: rateable_orders|length }) }}
                {% endif %}
            </p>
            <div class="d-flex flex-column gap-2">
                {% for o in rateable_orders %}
                    {% set label_key = o.rater_role == 'buyer' ? 'rating.label.rate_seller' : 'rating.label.rate_buyer' %}
                    {% set label = label_key|t %}
                    <div class="p-3 rounded-lg-aa border bg-white">
                        <div class="d-flex align-items-center gap-3">
                            {% if o.primary_image %}
                                <img src="{{ o.primary_image }}" alt="" style="width: 48px; height: 48px; object-fit: cover; border-radius: 0.5rem; flex-shrink: 0;">
                            {% else %}
                                <span class="aa-brand-badge d-inline-flex align-items-center justify-content-center" style="width: 48px; height: 48px; flex-shrink: 0;"><i class="bi bi-image"></i></span>
                            {% endif %}
                            <div class="flex-grow-1 min-w-0">
                                <a href="/auction/{{ o.item_id }}" class="text-decoration-none text-dark">
                                    <div class="fw-medium text-truncate">{{ o.title }}</div>
                                </a>
                                <div class="small text-muted-aa">
                                    {{ o.rater_role == 'buyer' ? ('public_profile.rate.you_bought'|t) : ('public_profile.rate.you_sold'|t) }}
                                    · {{ 'profile.orders.order_num'|t({ id: o.order_id }) }}
                                    {% if o.paid_at %} · {{ 'public_profile.rate.paid_on'|t({ date: o.paid_at|date('M j, Y') }) }}{% endif %}
                                </div>
                            </div>
                            <button class="btn btn-sm btn-outline-warning flex-shrink-0" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#rate-pp-{{ o.order_id }}"
                                    aria-expanded="false">
                                <i class="bi bi-star me-1"></i>{{ label }}
                            </button>
                        </div>
                        <div class="collapse" id="rate-pp-{{ o.order_id }}">
                            {% include 'partials/rate_form.twig' with { order_id: o.order_id, label: label, csrf: csrf } only %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    <div class="row g-4">
        <div class="col-lg-7">
            <h2 class="h5 mb-3">{{ 'public_profile.reviews_heading'|t }}</h2>
            {% include 'partials/reviews_panel.twig' with { stats: stats, reviews: reviews } only %}
        </div>

        <div class="col-lg-5">
            <h2 class="h5 mb-3">{{ 'public_profile.listings_by'|t({ name: profile_user.first_name }) }}</h2>
            {% if listings|length == 0 %}
                <p class="text-muted-aa small">{{ 'public_profile.no_listings'|t }}</p>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 g-3">
                    {% for auction in listings %}
                        <div class="col">{% include 'partials/auction_card.twig' with { auction: auction } only %}</div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
