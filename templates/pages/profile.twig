{% extends 'layout.twig' %}
{% block title %}{{ user.first_name }} {{ user.last_name }} — AnyAuction{% endblock %}

{% block content %}
<div class="container py-4">

    <div class="p-4 p-md-5 rounded-xl text-white mb-4"
         style="background: linear-gradient(135deg, #030213 0%, #1a1a2e 60%, #242443 100%);">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-3">
                {% if user.profile_picture %}
                    <img src="{{ user.profile_picture }}" class="rounded-circle" width="64" height="64" alt="">
                {% else %}
                    <span class="aa-brand-badge" style="width: 64px; height: 64px;">
                        <i class="bi bi-person fs-3"></i>
                    </span>
                {% endif %}
                <div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <h1 class="h3 text-white mb-0">{{ user.first_name }} {{ user.last_name }}</h1>
                        {% if user.is_verified %}
                            <i class="bi bi-patch-check-fill" style="color:#3b82f6;"></i>
                        {% endif %}
                        <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle text-capitalize">{{ user.role }}</span>
                    </div>
                    <div class="small text-white-50">@{{ user.username }} · {{ user.email }}</div>
                    <div class="small text-white-50 opacity-75">Member since {{ user.created_at|date('F Y') }}</div>
                </div>
            </div>
            <a href="/sell" class="btn btn-outline-light btn-sm align-self-start">
                <i class="bi bi-plus-lg me-1"></i>Create new listing
            </a>
        </div>

        <div class="row row-cols-3 row-cols-md-6 g-3 mt-3">
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.active_listings }}</div>
                <div class="small text-white-50">Active listings</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.total_listings }}</div>
                <div class="small text-white-50">Total listings</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.active_bids }}</div>
                <div class="small text-white-50">Active bids</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.watchlist }}</div>
                <div class="small text-white-50">Watching</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.rating }}</div>
                <div class="small text-white-50"><i class="bi bi-star-fill"></i> Rating</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.reviews }}</div>
                <div class="small text-white-50">Reviews</div>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4 flex-nowrap overflow-auto" role="tablist">
        <li class="nav-item"><button class="nav-link text-nowrap active" data-bs-toggle="tab" data-bs-target="#tab-listings"      type="button"><i class="bi bi-shop me-1"></i>My listings</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-sold"          type="button"><i class="bi bi-check-circle me-1"></i>Sold {% if sold|length > 0 %}<span class="badge bg-success-subtle text-success-emphasis ms-1">{{ sold|length }}</span>{% endif %}</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-bids"          type="button"><i class="bi bi-cart me-1"></i>My bids</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-won"           type="button"><i class="bi bi-trophy me-1"></i>Won {% if won|length > 0 %}<span class="badge bg-success-subtle text-success-emphasis ms-1">{{ won|length }}</span>{% endif %}</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-watchlist"     type="button"><i class="bi bi-heart me-1"></i>Watchlist</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-orders"        type="button"><i class="bi bi-box me-1"></i>Orders</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-reviews"       type="button"><i class="bi bi-chat-dots me-1"></i>Reviews</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-notifications" type="button"><i class="bi bi-bell me-1"></i>Notifications</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-settings"      type="button"><i class="bi bi-gear me-1"></i>Settings</button></li>
    </ul>

    <div class="tab-content">

        <div class="tab-pane fade show active" id="tab-listings" role="tabpanel">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="h5 mb-0">My listings</h2>
                    <div class="small text-muted-aa">{{ listings|length }} total</div>
                </div>
                <a href="/sell" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New listing</a>
            </div>
            {% if listings|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-shop fs-1 opacity-25 d-block mb-2"></i>
                    <p>You haven't created any listings yet.</p>
                    <a href="/sell" class="text-decoration-none">Create your first listing</a>
                </div>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
                    {% for auction in listings %}
                        <div class="col">{% include 'partials/auction_card.twig' with { auction: auction } only %}</div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-sold" role="tabpanel">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="h5 mb-0">Sold items</h2>
                    <div class="small text-muted-aa">{{ sold|length }} sold via Buy Now</div>
                </div>
            </div>
            {% if sold|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-check-circle fs-1 opacity-25 d-block mb-2"></i>
                    <p>No sold items yet. Sales will appear here once a buyer hits your buyout.</p>
                </div>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4 align-items-start">
                    {% for auction in sold %}
                        <div class="col">
                            {% include 'partials/auction_card.twig' with { auction: auction } only %}
                            {% set so = sold_orders_by_item[auction.item_id] ?? null %}
                            {% if so and so.status == 'paid' %}
                                <div class="mt-2">
                                    {% if rated_orders[so.order_id] %}
                                        <span class="badge bg-success-subtle text-success-emphasis w-100 d-block py-1"><i class="bi bi-check-circle me-1"></i>Rated buyer</span>
                                    {% else %}
                                        <button class="btn btn-sm btn-outline-warning w-100" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#rate-seller-{{ so.order_id }}"
                                                aria-expanded="false">
                                            <i class="bi bi-star me-1"></i>Rate buyer ({{ so.buyer_first_name }})
                                        </button>
                                        <div class="collapse" id="rate-seller-{{ so.order_id }}">
                                            {% include 'partials/rate_form.twig' with { order_id: so.order_id, label: 'Rate buyer', csrf: csrf } only %}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-bids" role="tabpanel">
            {% if bids|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-cart fs-1 opacity-25 d-block mb-2"></i>
                    <p>You haven't placed any bids yet.</p>
                    <a href="/browse" class="text-decoration-none">Browse auctions</a>
                </div>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
                    {% for auction in bids %}
                        <div class="col">{% include 'partials/auction_card.twig' with { auction: auction } only %}</div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-won" role="tabpanel">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="h5 mb-0">Auctions won</h2>
                    <div class="small text-muted-aa">{{ won|length }} won at buyout</div>
                </div>
            </div>
            {% if won|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-trophy fs-1 opacity-25 d-block mb-2"></i>
                    <p>You haven't won any auctions yet. Hit Buy Now on a listing to lock it in.</p>
                    <a href="/browse" class="text-decoration-none">Browse auctions</a>
                </div>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4 align-items-start">
                    {% for auction in won %}
                        <div class="col">
                            {% include 'partials/auction_card.twig' with { auction: auction } only %}
                            {% set wo = won_orders_by_item[auction.item_id] ?? null %}
                            {% if wo and wo.status == 'paid' %}
                                <div class="mt-2">
                                    {% if rated_orders[wo.order_id] %}
                                        <span class="badge bg-success-subtle text-success-emphasis w-100 d-block py-1"><i class="bi bi-check-circle me-1"></i>Rated seller</span>
                                    {% else %}
                                        <button class="btn btn-sm btn-outline-warning w-100" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#rate-won-{{ wo.order_id }}"
                                                aria-expanded="false">
                                            <i class="bi bi-star me-1"></i>Rate seller
                                        </button>
                                        <div class="collapse" id="rate-won-{{ wo.order_id }}">
                                            {% include 'partials/rate_form.twig' with { order_id: wo.order_id, label: 'Rate seller', csrf: csrf } only %}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-watchlist" role="tabpanel">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="h5 mb-0">Watchlist</h2>
                    <div class="small text-muted-aa">{{ watchlist|length }} item{{ watchlist|length == 1 ? '' : 's' }}</div>
                </div>
                <a href="/watchlist" class="btn btn-outline-secondary btn-sm">Open full watchlist</a>
            </div>
            {% if watchlist|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-heart fs-1 opacity-25 d-block mb-2"></i>
                    <p>Nothing watched yet. Click the heart on any listing to save it here.</p>
                    <a href="/browse" class="text-decoration-none">Browse auctions</a>
                </div>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
                    {% for auction in watchlist %}
                        <div class="col">{% include 'partials/auction_card.twig' with { auction: auction } only %}</div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-orders" role="tabpanel">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="h5 mb-0">Orders</h2>
                    <div class="small text-muted-aa">{{ orders|length }} total</div>
                </div>
            </div>
            {% if orders|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-box fs-1 opacity-25 d-block mb-2"></i>
                    <p>No orders yet. Win an auction and complete checkout to see it here.</p>
                </div>
            {% else %}
                <div class="d-flex flex-column gap-2">
                    {% for o in orders %}
                        <div class="p-3 rounded-lg-aa border">
                            <div class="d-flex align-items-center gap-3">
                                <a href="/auction/{{ o.item_id }}" class="flex-shrink-0">
                                    {% if o.primary_image %}
                                        <img src="{{ o.primary_image }}" alt="" style="width: 56px; height: 56px; object-fit: cover; border-radius: 0.5rem;">
                                    {% else %}
                                        <span class="aa-brand-badge d-inline-flex align-items-center justify-content-center" style="width: 56px; height: 56px;"><i class="bi bi-image fs-4"></i></span>
                                    {% endif %}
                                </a>
                                <div class="flex-grow-1 min-w-0">
                                    <a href="/auction/{{ o.item_id }}" class="text-decoration-none text-dark">
                                        <div class="fw-medium text-truncate">{{ o.title }}</div>
                                        <div class="small text-muted-aa">Order #{{ o.order_id }} · {{ o.created_at|date('M j, Y') }}</div>
                                    </a>
                                </div>
                                <div class="text-end flex-shrink-0">
                                    <div class="fw-medium">${{ o.amount|number_format(2) }}</div>
                                    {% if o.status == 'paid' %}
                                        <span class="badge bg-success-subtle text-success-emphasis">Paid</span>
                                    {% elseif o.status == 'pending' %}
                                        <span class="badge bg-warning-subtle text-warning-emphasis">Pending</span>
                                    {% elseif o.status == 'cancelled' %}
                                        <span class="badge bg-secondary-subtle text-secondary-emphasis">Cancelled</span>
                                    {% else %}
                                        <span class="badge bg-danger-subtle text-danger-emphasis">{{ o.status|capitalize }}</span>
                                    {% endif %}
                                </div>
                                {% if o.status == 'paid' %}
                                    <div class="flex-shrink-0">
                                        {% if rated_orders[o.order_id] %}
                                            <span class="badge bg-success-subtle text-success-emphasis"><i class="bi bi-check-circle me-1"></i>Rated</span>
                                        {% else %}
                                            <button class="btn btn-sm btn-outline-warning" type="button"
                                                    data-bs-toggle="collapse" data-bs-target="#rate-buyer-{{ o.order_id }}"
                                                    aria-expanded="false">
                                                <i class="bi bi-star me-1"></i>Rate seller
                                            </button>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                            {% if o.status == 'paid' and not rated_orders[o.order_id] %}
                                <div class="collapse" id="rate-buyer-{{ o.order_id }}">
                                    {% include 'partials/rate_form.twig' with { order_id: o.order_id, label: 'Rate seller', csrf: csrf } only %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-reviews" role="tabpanel">
            {% include 'partials/reviews_panel.twig' with { stats: stats, reviews: reviews } only %}
        </div>

        <div class="tab-pane fade" id="tab-notifications" role="tabpanel">
            <div class="text-center py-5 text-muted-aa">
                <i class="bi bi-bell fs-1 opacity-25 d-block mb-2"></i>
                <p>Notifications (outbid, won, snipe protection, order updates) come online alongside the Twilio + email stack.</p>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-settings" role="tabpanel">
            <div style="max-width: 32rem;">
                <h3 class="h6">Profile information</h3>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label small text-muted-aa">First name</label>
                        <input class="form-control" value="{{ user.first_name }}" disabled>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted-aa">Last name</label>
                        <input class="form-control" value="{{ user.last_name }}" disabled>
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted-aa">Email</label>
                        <input type="email" class="form-control" value="{{ user.email }}" disabled>
                    </div>
                </div>

                <h3 class="h6">Payout settings</h3>
                <div class="p-3 mb-4 rounded-lg-aa border border-success-subtle bg-success-subtle small">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <i class="bi bi-credit-card text-success"></i>
                        <span>Stripe Connected</span>
                        <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle">Active</span>
                    </div>
                    <div class="text-muted-aa">Payouts sent to your linked bank account every Friday. (Coming with Stripe integration.)</div>
                </div>

                <h3 class="h6">Notification preferences</h3>
                <div class="d-flex flex-column gap-2 mb-4">
                    {% for pref in [
                        'Email notifications for new bids on my listings',
                        'SMS notifications via Twilio (phone)',
                        'Outbid alerts for items I am bidding on',
                        'Weekly seller performance digest',
                        'Order update notifications'
                    ] %}
                        <label class="p-2 border rounded-lg-aa d-flex align-items-center gap-2 small">
                            <input type="checkbox" class="form-check-input" checked disabled>
                            {{ pref }}
                        </label>
                    {% endfor %}
                </div>

                <button class="btn btn-primary" disabled>Save settings</button>
                <p class="small text-muted-aa mt-2">Settings save is wired in a later phase.</p>
            </div>
        </div>

    </div>
</div>
{% endblock %}
