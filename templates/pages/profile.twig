{% extends 'layout.twig' %}
{% block title %}{{ user.first_name }} {{ user.last_name }} — AnyAuction{% endblock %}

{% block content %}
<div class="container py-4">

    <div class="p-4 p-md-5 rounded-xl text-white mb-4"
         style="background: linear-gradient(135deg, #030213 0%, #1a1a2e 60%, #242443 100%);">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-3">
                {% if user.profile_picture %}
                    <img src="{{ user.profile_picture }}" class="rounded-circle" width="64" height="64" alt="">
                {% else %}
                    <span class="aa-brand-badge" style="width: 64px; height: 64px;">
                        <i class="bi bi-person fs-3"></i>
                    </span>
                {% endif %}
                <div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <h1 class="h3 text-white mb-0">{{ user.first_name }} {{ user.last_name }}</h1>
                        {% if user.is_verified %}
                            <i class="bi bi-patch-check-fill" style="color:#3b82f6;"></i>
                        {% endif %}
                        <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle text-capitalize">{{ user.role }}</span>
                    </div>
                    <div class="small text-white-50">@{{ user.username }} · {{ user.email }}</div>
                    <div class="small text-white-50 opacity-75">{{ 'profile.member_since'|t({ date: user.created_at|date('F Y') }) }}</div>
                </div>
            </div>
            <a href="/sell" class="btn btn-outline-light btn-sm align-self-start">
                <i class="bi bi-plus-lg me-1"></i>{{ 'nav.create_listing'|t }}
            </a>
        </div>

        <div class="row row-cols-3 row-cols-md-6 g-3 mt-3">
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.active_listings }}</div>
                <div class="small text-white-50">{{ 'profile.stat.active_listings'|t }}</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.total_listings }}</div>
                <div class="small text-white-50">{{ 'profile.stat.total_listings'|t }}</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.active_bids }}</div>
                <div class="small text-white-50">{{ 'profile.stat.active_bids'|t }}</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.watchlist }}</div>
                <div class="small text-white-50">{{ 'profile.stat.watching'|t }}</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.rating }}</div>
                <div class="small text-white-50"><i class="bi bi-star-fill"></i> {{ 'profile.stat.rating'|t }}</div>
            </div>
            <div class="col">
                <div class="fs-5 text-amber">{{ stats.reviews }}</div>
                <div class="small text-white-50">{{ 'profile.stat.reviews'|t }}</div>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4 flex-nowrap overflow-auto" role="tablist">
        <li class="nav-item"><button class="nav-link text-nowrap active" data-bs-toggle="tab" data-bs-target="#tab-listings"      type="button"><i class="bi bi-shop me-1"></i>{{ 'profile.tab.listings'|t }}</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-sold"          type="button"><i class="bi bi-check-circle me-1"></i>{{ 'profile.tab.sold'|t }} {% if sold|length > 0 %}<span class="badge bg-success-subtle text-success-emphasis ms-1">{{ sold|length }}</span>{% endif %}</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-bids"          type="button"><i class="bi bi-cart me-1"></i>{{ 'profile.tab.bids'|t }}</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-won"           type="button"><i class="bi bi-trophy me-1"></i>{{ 'profile.tab.won'|t }} {% if won|length > 0 %}<span class="badge bg-success-subtle text-success-emphasis ms-1">{{ won|length }}</span>{% endif %}</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-watchlist"     type="button"><i class="bi bi-heart me-1"></i>{{ 'profile.tab.watchlist'|t }}</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-orders"        type="button"><i class="bi bi-box me-1"></i>{{ 'profile.tab.orders'|t }}</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-reviews"       type="button"><i class="bi bi-chat-dots me-1"></i>{{ 'profile.tab.reviews'|t }}</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-notifications" type="button" id="aa-notifs-tab"><i class="bi bi-bell me-1"></i>{{ 'profile.tab.notifications'|t }} {% if unread_notifs > 0 %}<span class="badge bg-warning text-dark ms-1">{{ unread_notifs }}</span>{% endif %}</button></li>
        <li class="nav-item"><button class="nav-link text-nowrap"        data-bs-toggle="tab" data-bs-target="#tab-settings"      type="button"><i class="bi bi-gear me-1"></i>{{ 'profile.tab.settings'|t }}</button></li>
    </ul>

    <div class="tab-content">

        <div class="tab-pane fade show active" id="tab-listings" role="tabpanel">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="h5 mb-0">{{ 'profile.listings.heading'|t }}</h2>
                    <div class="small text-muted-aa">{{ 'profile.listings.count'|t({ count: listings|length }) }}</div>
                </div>
                <a href="/sell" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>{{ 'profile.listings.new'|t }}</a>
            </div>
            {% if listings|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-shop fs-1 opacity-25 d-block mb-2"></i>
                    <p>{{ 'profile.listings.empty'|t }}</p>
                    <a href="/sell" class="text-decoration-none">{{ 'profile.listings.first'|t }}</a>
                </div>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
                    {% for auction in listings %}
                        <div class="col">{% include 'partials/auction_card.twig' with { auction: auction } only %}</div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-sold" role="tabpanel">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="h5 mb-0">{{ 'profile.sold.heading'|t }}</h2>
                    <div class="small text-muted-aa">{{ 'profile.sold.count'|t({ count: sold|length }) }}</div>
                </div>
            </div>
            {% if sold|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-check-circle fs-1 opacity-25 d-block mb-2"></i>
                    <p>{{ 'profile.sold.empty'|t }}</p>
                </div>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4 align-items-start">
                    {% for auction in sold %}
                        <div class="col">
                            {% include 'partials/auction_card.twig' with { auction: auction } only %}
                            {% set so = sold_orders_by_item[auction.item_id] ?? null %}
                            {% if so and so.status in ['pending','paid'] and (so.buyer_phone or so.buyer_email) %}
                                <div class="mt-2 p-2 rounded-lg-aa bg-surface-aa small">
                                    <div class="text-muted-aa mb-1"><i class="bi bi-person-lines-fill me-1"></i>{{ 'profile.sold.contact_buyer'|t }}</div>
                                    <div class="d-flex flex-column gap-1">
                                        <div><strong>{{ so.buyer_first_name }} {{ so.buyer_last_name }}</strong></div>
                                        {% if so.buyer_phone %}<a href="sms:{{ so.buyer_phone }}" class="text-decoration-none"><i class="bi bi-telephone me-1"></i>{{ so.buyer_phone }}</a>{% endif %}
                                        {% if so.buyer_email %}<a href="mailto:{{ so.buyer_email }}" class="text-decoration-none text-truncate d-inline-block"><i class="bi bi-envelope me-1"></i>{{ so.buyer_email }}</a>{% endif %}
                                    </div>
                                </div>
                            {% endif %}
                            {% if so and so.status == 'paid' %}
                                <div class="mt-2">
                                    {% if rated_orders[so.order_id] %}
                                        <span class="badge bg-success-subtle text-success-emphasis w-100 d-block py-1"><i class="bi bi-check-circle me-1"></i>{{ 'profile.sold.rated_buyer'|t }}</span>
                                    {% else %}
                                        <button class="btn btn-sm btn-outline-warning w-100" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#rate-seller-{{ so.order_id }}"
                                                aria-expanded="false">
                                            <i class="bi bi-star me-1"></i>{{ 'profile.sold.rate_buyer'|t({ name: so.buyer_first_name }) }}
                                        </button>
                                        <div class="collapse" id="rate-seller-{{ so.order_id }}">
                                            {% include 'partials/rate_form.twig' with { order_id: so.order_id, label: 'rating.label.rate_buyer'|t, csrf: csrf } only %}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-bids" role="tabpanel">
            {% if bids|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-cart fs-1 opacity-25 d-block mb-2"></i>
                    <p>{{ 'profile.bids.empty'|t }}</p>
                    <a href="/browse" class="text-decoration-none">{{ 'profile.bids.browse'|t }}</a>
                </div>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
                    {% for auction in bids %}
                        <div class="col">{% include 'partials/auction_card.twig' with { auction: auction } only %}</div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-won" role="tabpanel">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="h5 mb-0">{{ 'profile.won.heading'|t }}</h2>
                    <div class="small text-muted-aa">{{ 'profile.won.count'|t({ count: won|length }) }}</div>
                </div>
            </div>
            {% if won|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-trophy fs-1 opacity-25 d-block mb-2"></i>
                    <p>{{ 'profile.won.empty'|t }}</p>
                    <a href="/browse" class="text-decoration-none">{{ 'profile.bids.browse'|t }}</a>
                </div>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4 align-items-start">
                    {% for auction in won %}
                        <div class="col">
                            {% include 'partials/auction_card.twig' with { auction: auction } only %}
                            {% set wo = won_orders_by_item[auction.item_id] ?? null %}
                            {% if wo and wo.status == 'paid' %}
                                <div class="mt-2">
                                    {% if rated_orders[wo.order_id] %}
                                        <span class="badge bg-success-subtle text-success-emphasis w-100 d-block py-1"><i class="bi bi-check-circle me-1"></i>{{ 'profile.won.rated_seller'|t }}</span>
                                    {% else %}
                                        <button class="btn btn-sm btn-outline-warning w-100" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#rate-won-{{ wo.order_id }}"
                                                aria-expanded="false">
                                            <i class="bi bi-star me-1"></i>{{ 'profile.won.rate_seller'|t }}
                                        </button>
                                        <div class="collapse" id="rate-won-{{ wo.order_id }}">
                                            {% include 'partials/rate_form.twig' with { order_id: wo.order_id, label: 'rating.label.rate_seller'|t, csrf: csrf } only %}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-watchlist" role="tabpanel">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="h5 mb-0">{{ 'profile.watchlist.heading'|t }}</h2>
                    <div class="small text-muted-aa">
                        {% if watchlist|length == 1 %}
                            {{ 'profile.watchlist.count_one'|t({ count: watchlist|length }) }}
                        {% else %}
                            {{ 'profile.watchlist.count_many'|t({ count: watchlist|length }) }}
                        {% endif %}
                    </div>
                </div>
                <a href="/watchlist" class="btn btn-outline-secondary btn-sm">{{ 'profile.watchlist.open_full'|t }}</a>
            </div>
            {% if watchlist|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-heart fs-1 opacity-25 d-block mb-2"></i>
                    <p>{{ 'profile.watchlist.empty'|t }}</p>
                    <a href="/browse" class="text-decoration-none">{{ 'profile.bids.browse'|t }}</a>
                </div>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
                    {% for auction in watchlist %}
                        <div class="col">{% include 'partials/auction_card.twig' with { auction: auction } only %}</div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-orders" role="tabpanel">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="h5 mb-0">{{ 'profile.orders.heading'|t }}</h2>
                    <div class="small text-muted-aa">{{ 'profile.orders.count'|t({ count: orders|length }) }}</div>
                </div>
            </div>
            {% if orders|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-box fs-1 opacity-25 d-block mb-2"></i>
                    <p>{{ 'profile.orders.empty'|t }}</p>
                </div>
            {% else %}
                <div class="d-flex flex-column gap-2">
                    {% for o in orders %}
                        <div class="p-3 rounded-lg-aa border">
                            <div class="d-flex align-items-center gap-3">
                                <a href="/auction/{{ o.item_id }}" class="flex-shrink-0">
                                    {% if o.primary_image %}
                                        <img src="{{ o.primary_image }}" alt="" style="width: 56px; height: 56px; object-fit: cover; border-radius: 0.5rem;">
                                    {% else %}
                                        <span class="aa-brand-badge d-inline-flex align-items-center justify-content-center" style="width: 56px; height: 56px;"><i class="bi bi-image fs-4"></i></span>
                                    {% endif %}
                                </a>
                                <div class="flex-grow-1 min-w-0">
                                    <a href="/auction/{{ o.item_id }}" class="text-decoration-none text-dark">
                                        <div class="fw-medium text-truncate">{{ o.title }}</div>
                                        <div class="small text-muted-aa">{{ 'profile.orders.order_num'|t({ id: o.order_id }) }} · {{ o.created_at|date('M j, Y') }}</div>
                                    </a>
                                </div>
                                <div class="text-end flex-shrink-0">
                                    <div class="fw-medium">${{ o.amount|number_format(2) }}</div>
                                    {% if o.status == 'paid' %}
                                        <span class="badge bg-success-subtle text-success-emphasis">{{ 'profile.orders.status.paid'|t }}</span>
                                    {% elseif o.status == 'pending' %}
                                        <span class="badge bg-warning-subtle text-warning-emphasis">{{ 'profile.orders.status.pending'|t }}</span>
                                    {% elseif o.status == 'cancelled' %}
                                        <span class="badge bg-secondary-subtle text-secondary-emphasis">{{ 'profile.orders.status.cancelled'|t }}</span>
                                    {% else %}
                                        <span class="badge bg-danger-subtle text-danger-emphasis">{{ o.status|capitalize }}</span>
                                    {% endif %}
                                </div>
                                {% if o.status == 'paid' %}
                                    <div class="flex-shrink-0">
                                        {% if rated_orders[o.order_id] %}
                                            <span class="badge bg-success-subtle text-success-emphasis"><i class="bi bi-check-circle me-1"></i>{{ 'profile.orders.rated'|t }}</span>
                                        {% else %}
                                            <button class="btn btn-sm btn-outline-warning" type="button"
                                                    data-bs-toggle="collapse" data-bs-target="#rate-buyer-{{ o.order_id }}"
                                                    aria-expanded="false">
                                                <i class="bi bi-star me-1"></i>{{ 'profile.orders.rate_seller'|t }}
                                            </button>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                            {% if o.status in ['pending','paid'] and (o.seller_phone or o.seller_email) %}
                                <div class="mt-2 p-2 rounded-lg-aa bg-surface-aa small">
                                    <div class="text-muted-aa mb-1"><i class="bi bi-person-lines-fill me-1"></i>{{ 'profile.orders.contact_seller'|t }}</div>
                                    <div class="d-flex flex-wrap gap-3">
                                        <span><strong>{{ o.seller_first_name }} {{ o.seller_last_name }}</strong> <a href="/users/{{ o.seller_id }}" class="text-muted-aa text-decoration-none">@{{ o.seller_username }}</a></span>
                                        {% if o.seller_phone %}<a href="sms:{{ o.seller_phone }}" class="text-decoration-none"><i class="bi bi-telephone me-1"></i>{{ o.seller_phone }}</a>{% endif %}
                                        {% if o.seller_email %}<a href="mailto:{{ o.seller_email }}" class="text-decoration-none"><i class="bi bi-envelope me-1"></i>{{ o.seller_email }}</a>{% endif %}
                                    </div>
                                </div>
                            {% endif %}
                            {% if o.status == 'paid' and not rated_orders[o.order_id] %}
                                <div class="collapse" id="rate-buyer-{{ o.order_id }}">
                                    {% include 'partials/rate_form.twig' with { order_id: o.order_id, label: 'rating.label.rate_seller'|t, csrf: csrf } only %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-reviews" role="tabpanel">
            {% include 'partials/reviews_panel.twig' with { stats: stats, reviews: reviews } only %}
        </div>

        <div class="tab-pane fade" id="tab-notifications" role="tabpanel">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="h5 mb-0">{{ 'profile.notifs.heading'|t }}</h2>
                    <div class="small text-muted-aa">{{ 'profile.notifs.recent'|t({ recent: notifications|length, unread: unread_notifs }) }}</div>
                </div>
            </div>
            {% if notifications|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-bell fs-1 opacity-25 d-block mb-2"></i>
                    <p>{{ 'profile.notifs.empty'|t }}</p>
                </div>
            {% else %}
                <div class="d-flex flex-column gap-2">
                    {% for n in notifications %}
                        {% set icon = 'bi-bell' %}
                        {% set tone = 'secondary' %}
                        {% if n.type == 'outbid' %}{% set icon = 'bi-arrow-up-circle' %}{% set tone = 'warning' %}
                        {% elseif n.type == 'auction_won' %}{% set icon = 'bi-trophy-fill' %}{% set tone = 'success' %}
                        {% elseif n.type == 'auction_lost' %}{% set icon = 'bi-x-circle' %}{% set tone = 'secondary' %}
                        {% elseif n.type == 'snipe_extended' %}{% set icon = 'bi-stopwatch' %}{% set tone = 'info' %}
                        {% elseif n.type == 'bid_received' %}{% set icon = 'bi-cash-coin' %}{% set tone = 'info' %}
                        {% elseif n.type == 'item_sold' %}{% set icon = 'bi-check-circle-fill' %}{% set tone = 'success' %}
                        {% elseif n.type == 'order_paid' %}{% set icon = 'bi-credit-card-2-front' %}{% set tone = 'success' %}
                        {% elseif n.type == 'welcome' %}{% set icon = 'bi-stars' %}{% set tone = 'warning' %}
                        {% elseif n.type starts with 'watchlist_' %}{% set icon = 'bi-heart' %}{% set tone = 'danger' %}
                        {% endif %}
                        <a href="{{ n.href|default('#') }}" data-aa-notif-id="{{ n.notification_id }}" class="d-flex align-items-start gap-3 p-3 rounded-lg-aa border text-decoration-none text-dark {% if n.is_read == 0 %}bg-warning-subtle{% endif %}">
                            <span class="aa-brand-badge bg-{{ tone }}-subtle text-{{ tone }}-emphasis d-inline-flex align-items-center justify-content-center" style="width: 40px; height: 40px; flex-shrink: 0;">
                                <i class="bi {{ icon }} fs-5"></i>
                            </span>
                            <div class="flex-grow-1 min-w-0">
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <div class="fw-medium">{{ n.title }}</div>
                                    {% if n.is_read == 0 %}<span class="badge bg-warning text-dark">{{ 'profile.notifs.new'|t }}</span>{% endif %}
                                </div>
                                {% if n.body %}<div class="small text-muted-aa">{{ n.body }}</div>{% endif %}
                                <div class="small text-muted-aa opacity-75">{{ n.created_at|date('M j, Y g:i a') }}</div>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-settings" role="tabpanel">
            <div style="max-width: 32rem;">
                <h3 class="h6">{{ 'profile.settings.profile'|t }}</h3>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label small text-muted-aa">{{ 'auth.register.first_name'|t }}</label>
                        <input class="form-control" value="{{ user.first_name }}" disabled>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted-aa">{{ 'auth.register.last_name'|t }}</label>
                        <input class="form-control" value="{{ user.last_name }}" disabled>
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted-aa">{{ 'auth.login.email'|t }}</label>
                        <input type="email" class="form-control" value="{{ user.email }}" disabled>
                    </div>
                </div>

                <h3 class="h6">{{ 'profile.settings.payout'|t }}</h3>
                <div class="p-3 mb-4 rounded-lg-aa border border-success-subtle bg-success-subtle small">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <i class="bi bi-credit-card text-success"></i>
                        <span>{{ 'profile.settings.payout.connected'|t }}</span>
                        <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle">{{ 'profile.settings.payout.active'|t }}</span>
                    </div>
                    <div class="text-muted-aa">{{ 'profile.settings.payout.note'|t }}</div>
                </div>

                <h3 class="h6">{{ 'profile.settings.notifs'|t }}</h3>
                <div class="d-flex flex-column gap-2 mb-4">
                    {% for pref_key in [
                        'profile.settings.pref.email_bids',
                        'profile.settings.pref.sms_twilio',
                        'profile.settings.pref.outbid',
                        'profile.settings.pref.weekly_digest',
                        'profile.settings.pref.order_updates'
                    ] %}
                        <label class="p-2 border rounded-lg-aa d-flex align-items-center gap-2 small">
                            <input type="checkbox" class="form-check-input" checked disabled>
                            {{ pref_key|t }}
                        </label>
                    {% endfor %}
                </div>

                <button class="btn btn-primary" disabled>{{ 'profile.settings.save'|t }}</button>
                <p class="small text-muted-aa mt-2">{{ 'profile.settings.save_note'|t }}</p>
            </div>
        </div>

    </div>
</div>

{#
   Two scripts on this page:
     1. activateTabFromHash — when /profile#tab-notifications is loaded
        (e.g. via the bell icon in the navbar), open that tab instead of
        the default "My listings". Also responds to in-page hash changes.
     2. mark-read on shown.bs.tab — clears server-side unread + the
        navbar/tab badges as soon as the user actually views the tab.
#}
<script>
    // Defer until Bootstrap (loaded at the bottom of layout.twig) is ready.
    document.addEventListener('DOMContentLoaded', function () {
        // 1. Hash → tab activation. Map an exact hash like "#tab-notifications"
        //    to the tab button that targets that pane. Bootstrap's Tab API
        //    handles the visual swap.
        var activateTabFromHash = function () {
            var hash = window.location.hash || '';
            if (hash.length < 2) return;
            var trigger = document.querySelector('[data-bs-toggle="tab"][data-bs-target="' + hash + '"]');
            if (trigger && window.bootstrap && window.bootstrap.Tab) {
                window.bootstrap.Tab.getOrCreateInstance(trigger).show();
            }
        };
        activateTabFromHash();
        window.addEventListener('hashchange', activateTabFromHash);

        // 2. Mark-as-read when the Notifications tab is shown. Sweeps the
        //    navbar bell badge + the tab-label badge so the unread count
        //    visually clears in step with the server.
        var trigger = document.getElementById('aa-notifs-tab');
        if (!trigger) return;
        trigger.addEventListener('shown.bs.tab', function () {
            var csrf = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';
            fetch('/api/notifications/mark-read', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'X-CSRF-Token': csrf, 'Content-Type': 'application/json' },
            }).then(function () {
                document.querySelectorAll('.aa-bell-badge, #aa-notifs-tab .badge').forEach(function (el) {
                    el.remove();
                });
                // Drop the unread highlight from the rendered list too.
                document.querySelectorAll('#tab-notifications .bg-warning-subtle').forEach(function (row) {
                    row.classList.remove('bg-warning-subtle');
                    var newPill = row.querySelector('.badge.bg-warning.text-dark');
                    if (newPill) newPill.remove();
                });
            }).catch(function () { /* silent */ });
        });
    });
</script>
{% endblock %}
