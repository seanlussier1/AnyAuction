{% extends 'layout.twig' %}
{% block title %}Admin dashboard — AnyAuction{% endblock %}

{% block content %}
<div class="container py-4">

    <div class="d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-speedometer2 fs-4"></i>
        <h1 class="h3 mb-0">Admin Dashboard</h1>
    </div>

    <ul class="nav nav-tabs mb-4 flex-nowrap overflow-auto" role="tablist">
        <li class="nav-item">
            <button class="nav-link {{ active_tab == 'overview' ? 'active' : '' }}" data-bs-toggle="tab" data-bs-target="#adm-overview" type="button">
                <i class="bi bi-grid-1x2 me-1"></i>Overview
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link {{ active_tab == 'users' ? 'active' : '' }}" data-bs-toggle="tab" data-bs-target="#adm-users" type="button">
                <i class="bi bi-people me-1"></i>Users
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link {{ active_tab == 'listings' ? 'active' : '' }}" data-bs-toggle="tab" data-bs-target="#adm-listings" type="button">
                <i class="bi bi-box-seam me-1"></i>Listings
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link {{ active_tab == 'reports' ? 'active' : '' }}" data-bs-toggle="tab" data-bs-target="#adm-reports" type="button">
                <i class="bi bi-flag me-1"></i>Reports
                {% set pending = reports|filter(r => r.status == 'pending')|length %}
                {% if pending > 0 %}<span class="badge bg-danger ms-1">{{ pending }}</span>{% endif %}
            </button>
        </li>
    </ul>

    <div class="tab-content">

        <div class="tab-pane fade {{ active_tab == 'overview' ? 'show active' : '' }}" id="adm-overview" role="tabpanel">
            <div class="row row-cols-2 row-cols-lg-4 g-3 mb-4">
                <div class="col">
                    <div class="p-4 border rounded-xl h-100">
                        <div class="rounded-lg-aa d-inline-flex align-items-center justify-content-center mb-3" style="width:40px; height:40px; background:rgba(59,130,246,.1); color:#2563eb;">
                            <i class="bi bi-box-seam"></i>
                        </div>
                        <div class="fs-3">{{ stats.active_auctions }}</div>
                        <div class="small text-muted-aa">Active auctions</div>
                    </div>
                </div>
                <div class="col">
                    <div class="p-4 border rounded-xl h-100">
                        <div class="rounded-lg-aa d-inline-flex align-items-center justify-content-center mb-3" style="width:40px; height:40px; background:rgba(16,185,129,.1); color:var(--aa-emerald);">
                            <i class="bi bi-people"></i>
                        </div>
                        <div class="fs-3">{{ stats.total_users }}</div>
                        <div class="small text-muted-aa">Total users</div>
                    </div>
                </div>
                <div class="col">
                    <div class="p-4 border rounded-xl h-100">
                        <div class="rounded-lg-aa d-inline-flex align-items-center justify-content-center mb-3" style="width:40px; height:40px; background:rgba(245,158,11,.15); color:var(--aa-amber);">
                            <i class="bi bi-exclamation-triangle"></i>
                        </div>
                        <div class="fs-3">{{ stats.pending_reports }}</div>
                        <div class="small text-muted-aa">Pending reports</div>
                    </div>
                </div>
                <div class="col">
                    <div class="p-4 border rounded-xl h-100">
                        <div class="rounded-lg-aa d-inline-flex align-items-center justify-content-center mb-3" style="width:40px; height:40px; background:rgba(139,92,246,.1); color:#7c3aed;">
                            <i class="bi bi-graph-up"></i>
                        </div>
                        <div class="fs-3">{{ stats.revenue_30d }}</div>
                        <div class="small text-muted-aa">Revenue (30d)</div>
                    </div>
                </div>
            </div>

            <div class="border rounded-xl p-4 mb-4">
                <h3 class="h6 mb-3">Listings by category</h3>
                <div class="row row-cols-2 row-cols-md-4 g-2">
                    {% for cat in category_counts %}
                        <div class="col">
                            <div class="p-3 bg-surface-aa rounded-lg-aa d-flex justify-content-between align-items-center">
                                <span class="small">{{ cat.name }}</span>
                                <span class="small text-muted-aa">{{ cat.count }}</span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="border rounded-xl p-4">
                <h3 class="h6 mb-3">Recent reports</h3>
                {% set pending = reports|filter(r => r.status == 'pending') %}
                {% if pending|length == 0 %}
                    <p class="text-muted-aa small mb-0">Nothing pending. All clear.</p>
                {% else %}
                    <div class="d-flex flex-column gap-2">
                        {% for r in pending|slice(0, 5) %}
                            <a href="/admin?tab=reports" class="d-flex align-items-center justify-content-between p-3 bg-warning-subtle border border-warning-subtle rounded-lg-aa text-decoration-none text-dark">
                                <div class="d-flex align-items-center gap-3">
                                    <i class="bi bi-exclamation-triangle text-warning-emphasis"></i>
                                    <div>
                                        <div class="small">{{ r.item_title|default(r.reported_username|default('—')) }}</div>
                                        <div class="text-muted-aa" style="font-size: 0.75rem;">{{ r.reason }} — by @{{ r.reporter_username }}</div>
                                    </div>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="tab-pane fade {{ active_tab == 'users' ? 'show active' : '' }}" id="adm-users" role="tabpanel">
            <form method="get" action="/admin" class="mb-3" style="max-width: 24rem;">
                <input type="hidden" name="tab" value="users">
                <div class="input-group">
                    <span class="input-group-text bg-surface-aa border-0"><i class="bi bi-search"></i></span>
                    <input type="search" name="uq" class="form-control bg-surface-aa border-0"
                           placeholder="Search by username or email…"
                           value="{{ user_search }}">
                </div>
            </form>

            <div class="border rounded-xl overflow-hidden">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-surface-aa small text-muted-aa">
                            <tr>
                                <th class="px-3">User</th>
                                <th class="px-3 d-none d-md-table-cell">Role</th>
                                <th class="px-3 d-none d-md-table-cell">Verified</th>
                                <th class="px-3 d-none d-lg-table-cell">Status</th>
                                <th class="px-3 d-none d-xl-table-cell">Joined</th>
                                <th class="px-3 text-end">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            {% for u in users %}
                                <tr>
                                    <td class="px-3">
                                        <div class="d-flex align-items-center gap-2">
                                            {% if u.profile_picture %}
                                                <img src="{{ u.profile_picture }}" alt="" class="rounded-circle" width="32" height="32">
                                            {% else %}
                                                <span class="aa-brand-badge" style="width: 32px; height: 32px;">
                                                    <i class="bi bi-person"></i>
                                                </span>
                                            {% endif %}

                                            <div>
                                                <div>{{ u.username }}</div>
                                                <div class="small text-muted-aa">{{ u.email }}</div>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="px-3 d-none d-md-table-cell">
                                        {% set badge = u.role == 'admin' ? 'primary-subtle text-primary-emphasis' :
                                                       u.role == 'seller' ? 'info-subtle text-info-emphasis' :
                                                                            'secondary-subtle text-secondary-emphasis' %}
                                        <span class="badge bg-{{ badge }} text-capitalize">{{ u.role }}</span>
                                    </td>

                                    <td class="px-3 d-none d-md-table-cell">
                                        {% if u.is_verified %}
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                        {% else %}
                                            <i class="bi bi-x-circle text-muted-aa"></i>
                                        {% endif %}
                                    </td>

                                    <td class="px-3 d-none d-lg-table-cell">
                                        {% set userStatus = u.account_status|default('active') %}
                                        {% set statusBadge = userStatus == 'banned' ? 'danger-subtle text-danger-emphasis' :
                                                             userStatus == 'warned' ? 'warning-subtle text-warning-emphasis' :
                                                                                      'success-subtle text-success-emphasis' %}

                                        <span class="badge bg-{{ statusBadge }} text-capitalize">{{ userStatus }}</span>

                                        {% if u.warning_note %}
                                            <div class="small text-muted-aa mt-1">{{ u.warning_note }}</div>
                                        {% endif %}
                                    </td>

                                    <td class="px-3 d-none d-xl-table-cell small">
                                        {{ u.created_at|date('M j, Y') }}
                                    </td>

                                    <td class="px-3 text-end">
                                        <div class="d-flex justify-content-end gap-1 flex-wrap">
                                            <a href="/users/{{ u.user_id }}" class="btn btn-sm btn-outline-secondary" title="View profile">
                                                <i class="bi bi-eye"></i>
                                            </a>

                                            {% if u.role != 'admin' %}
                                                <form action="/admin/users/{{ u.user_id }}/warn" method="post" class="m-0">
                                                    <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                                                    <input type="hidden" name="warning_note" value="Flagged by admin">
                                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="Warn user">
                                                        <i class="bi bi-exclamation-triangle"></i>
                                                    </button>
                                                </form>

                                                {% if userStatus == 'banned' %}
                                                    <form action="/admin/users/{{ u.user_id }}/unban" method="post" class="m-0">
                                                        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Unban user">
                                                            <i class="bi bi-check-circle"></i>
                                                        </button>
                                                    </form>
                                                {% else %}
                                                    <form action="/admin/users/{{ u.user_id }}/ban" method="post" class="m-0" onsubmit="return confirm('Ban this user?');">
                                                        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Ban user">
                                                            <i class="bi bi-slash-circle"></i>
                                                        </button>
                                                    </form>
                                                {% endif %}
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center text-muted-aa py-4">No users matched.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="tab-pane fade {{ active_tab == 'listings' ? 'show active' : '' }}" id="adm-listings" role="tabpanel">
            <div class="d-flex flex-column gap-2">
                {% for a in listings %}
                    <div class="d-flex align-items-center justify-content-between p-3 border rounded-xl">
                        <div class="d-flex align-items-center gap-3">
                            {% if a.primary_image %}
                                <img src="{{ a.primary_image }}" alt="" class="rounded-lg-aa object-fit-cover" width="56" height="56" style="object-fit: cover;">
                            {% else %}
                                <div class="bg-surface-aa rounded-lg-aa d-flex align-items-center justify-content-center" style="width:56px; height:56px;">
                                    <i class="bi bi-image text-muted-aa"></i>
                                </div>
                            {% endif %}

                            <div>
                                <div class="small">{{ a.title }}</div>
                                <div class="small text-muted-aa">
                                    {{ a.seller_username }} · {{ a.category_name }} · ${{ a.current_price|number_format(2) }} · {{ a.total_bids }} bids

                                    {% set shownStatus = a.display_status|default(a.status) %}
                                    {% set sb = shownStatus == 'active' ? 'success-subtle text-success-emphasis' :
                                                shownStatus == 'cancelled' ? 'danger-subtle text-danger-emphasis' :
                                                                             'secondary-subtle text-secondary-emphasis' %}

                                    <span class="badge bg-{{ sb }} ms-1 text-capitalize">{{ shownStatus }}</span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-1">
                            <a href="/auction/{{ a.item_id }}" class="btn btn-sm btn-outline-secondary" title="View listing">
                                <i class="bi bi-eye"></i>
                            </a>

                            {% if a.status != 'cancelled' %}
                                <form action="/admin/listings/{{ a.item_id }}/remove" method="post" class="m-0" onsubmit="return confirm('Remove this listing?');">
                                    <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove listing">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <p class="text-center text-muted-aa py-4">No listings yet.</p>
                {% endfor %}
            </div>
        </div>

        <div class="tab-pane fade {{ active_tab == 'reports' ? 'show active' : '' }}" id="adm-reports" role="tabpanel">
            {% if reports|length == 0 %}
                <div class="text-center py-5 text-muted-aa">
                    <i class="bi bi-flag fs-1 opacity-25 d-block mb-2"></i>
                    <p>No reports yet. Listings and users that get flagged will appear here.</p>
                </div>
            {% else %}
                <div class="d-flex flex-column gap-2">
                    {% for r in reports %}
                        {% set statusBadge = r.status == 'pending' ? 'warning-subtle text-warning-emphasis' :
                                              r.status == 'resolved' ? 'success-subtle text-success-emphasis' :
                                                                       'secondary-subtle text-secondary-emphasis' %}
                        {% set typeBadge = r.type == 'user' ? 'info-subtle text-info-emphasis' : 'primary-subtle text-primary-emphasis' %}

                        <div class="p-3 border rounded-xl {{ r.status == 'pending' ? 'border-warning-subtle bg-warning-subtle bg-opacity-25' : '' }}">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div class="flex-grow-1 min-w-0">
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <span class="badge bg-{{ typeBadge }} text-capitalize">{{ r.type }}</span>

                                        {% if r.type == 'listing' and r.item_id %}
                                            <a href="/auction/{{ r.item_id }}" class="text-decoration-none">{{ r.item_title|default('(deleted listing)') }}</a>
                                        {% elseif r.type == 'user' and r.reported_user_id %}
                                            <a href="/users/{{ r.reported_user_id }}" class="text-decoration-none">@{{ r.reported_username }}</a>
                                        {% else %}
                                            <span class="text-muted-aa">(removed)</span>
                                        {% endif %}

                                        <span class="badge bg-{{ statusBadge }} text-capitalize">{{ r.status }}</span>
                                    </div>

                                    <div class="small text-muted-aa mt-1">
                                        <strong>Reason:</strong> {{ r.reason }}
                                    </div>

                                    {% if r.details %}
                                        <div class="small mt-1" style="white-space: pre-wrap;">{{ r.details }}</div>
                                    {% endif %}

                                    <div class="small text-muted-aa" style="font-size: 0.7rem;">
                                        Reported by @{{ r.reporter_username }} on {{ r.created_at|date('M j, Y g:i a') }}
                                        {% if r.resolved_at %}· {{ r.status }} {{ r.resolved_at|date('M j, Y') }}{% endif %}
                                    </div>
                                </div>

                                {% if r.status == 'pending' and is_real_admin %}
                                    <div class="d-flex gap-2 flex-shrink-0">
                                        <form action="/report/{{ r.report_id }}/resolve" method="post" class="m-0">
                                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                                            <button type="submit" class="btn btn-sm btn-success">Resolve</button>
                                        </form>

                                        <form action="/report/{{ r.report_id }}/dismiss" method="post" class="m-0">
                                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">Dismiss</button>
                                        </form>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

    </div>
</div>
{% endblock %}
