{% extends 'layout.twig' %}
{% block title %}
    {% if active_category %}{{ active_category.name }}
    {% elseif query %}Results for "{{ query }}"
    {% else %}Browse auctions
    {% endif %}
    — AnyAuction
{% endblock %}

{% block content %}
<div class="container py-4">

    <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-0">
                {% if active_category %}{{ active_category.name }}
                {% elseif query %}Results for &ldquo;{{ query }}&rdquo;
                {% else %}Browse Auctions
                {% endif %}
            </h1>
            <div class="small text-muted-aa">{{ result_count }} auction{{ result_count == 1 ? '' : 's' }} found</div>
        </div>

        <form method="get" action="/browse" class="d-flex gap-2 align-items-center">
            {% if active_category %}<input type="hidden" name="category" value="{{ active_category.category_id }}">{% endif %}
            {% if query %}<input type="hidden" name="q" value="{{ query }}">{% endif %}

            <button type="button" class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1"
                    data-bs-toggle="collapse" data-bs-target="#advancedFilters">
                <i class="bi bi-sliders"></i> Filters
            </button>
            <select name="sort" class="form-select form-select-sm" onchange="this.form.submit()" style="width: auto;">
                <option value="ending"     {{ active_sort == 'ending'     ? 'selected' : '' }}>Ending Soonest</option>
                <option value="price-low"  {{ active_sort == 'price-low'  ? 'selected' : '' }}>Price: Low to High</option>
                <option value="price-high" {{ active_sort == 'price-high' ? 'selected' : '' }}>Price: High to Low</option>
                <option value="newest"     {{ active_sort == 'newest'     ? 'selected' : '' }}>Newest</option>
            </select>
        </form>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a href="/browse{% if query %}?q={{ query }}{% endif %}"
           class="btn btn-sm rounded-pill {{ not active_category ? 'btn-primary' : 'btn-outline-secondary' }}">All</a>
        {% for cat in categories %}
            <a href="/browse?category={{ cat.category_id }}{% if query %}&q={{ query }}{% endif %}"
               class="btn btn-sm rounded-pill {{ active_category and active_category.category_id == cat.category_id ? 'btn-primary' : 'btn-outline-secondary' }}">
                <i class="bi bi-{{ cat.icon }} me-1"></i>{{ cat.name }}
            </a>
        {% endfor %}
    </div>

    <div class="collapse mb-4" id="advancedFilters">
        <div class="p-4 bg-surface-aa rounded-lg-aa border">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h5 class="mb-0">Filters</h5>
                <span class="small text-muted-aa"><i class="bi bi-info-circle me-1"></i>Backend wiring comes in a later deliverable</span>
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small text-muted-aa">Min price</label>
                    <input type="number" class="form-control" placeholder="0">
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted-aa">Max price</label>
                    <input type="number" class="form-control" placeholder="Any">
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted-aa d-block">Condition</label>
                    <div class="d-flex flex-wrap gap-1">
                        {% for c in ['New', 'Like New', 'Excellent', 'Good', 'Fair'] %}
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill">{{ c }}</button>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% if auctions|length == 0 %}
        <div class="text-center py-5 text-muted-aa">
            <i class="bi bi-search fs-1 opacity-25 d-block mb-3"></i>
            <p>No auctions found matching your criteria.</p>
            <a href="/browse" class="btn btn-primary mt-2">Clear filters</a>
        </div>
    {% else %}
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
            {% for auction in auctions %}
                <div class="col">
                    {% include 'partials/auction_card.twig' with { auction: auction } only %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
