{% extends 'layout.twig' %}
{% block title %}Create an account — AnyAuction{% endblock %}

{% block content %}
<div class="container py-5" style="max-width: 30rem;">
    <a href="/" class="d-flex align-items-center gap-2 text-decoration-none text-dark mb-4">
        <span class="aa-brand-badge"><i class="bi bi-hammer"></i></span>
        <span class="fs-5">AnyAuction</span>
    </a>

    <h1 class="h3 mb-1">Create your account</h1>
    <p class="text-muted-aa mb-4">Start bidding and selling in minutes.</p>

    <form method="post" action="/register" class="d-flex flex-column gap-3">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
        <div class="row g-3">
            <div class="col">
                <label class="form-label small text-muted-aa">First name</label>
                <input name="first_name" class="form-control" required value="{{ old.firstName|default('') }}">
            </div>
            <div class="col">
                <label class="form-label small text-muted-aa">Last name</label>
                <input name="last_name" class="form-control" required value="{{ old.lastName|default('') }}">
            </div>
        </div>
        <div>
            <label class="form-label small text-muted-aa">Email</label>
            <input type="email" name="email" class="form-control" required value="{{ old.email|default('') }}">
        </div>
        <div>
            <label class="form-label small text-muted-aa">Username</label>
            <input name="username" class="form-control" required minlength="3" maxlength="50" value="{{ old.username|default('') }}">
        </div>
        <div>
            <label class="form-label small text-muted-aa">Phone</label>
            <input type="tel" name="phone" class="form-control" required
                   placeholder="5551234567"
                   autocomplete="tel"
                   inputmode="numeric"
                   pattern="[0-9]*"
                   maxlength="11"
                   data-aa-digits-only
                   value="{{ old.phone|default('') }}">
            <div class="form-text">US or Canada — digits only. We'll text you a verification code.</div>
        </div>
        <div>
            <label class="form-label small text-muted-aa">Password</label>
            <input type="password" name="password" class="form-control" required minlength="8">
            <div class="form-text">At least 8 characters.</div>
        </div>
        <div>
            <label class="form-label small text-muted-aa">Confirm password</label>
            <input type="password" name="password_confirm" class="form-control" required minlength="8">
        </div>

        <button type="submit" class="btn btn-primary py-2">Create account <i class="bi bi-arrow-right ms-1"></i></button>
    </form>

    <p class="text-center small text-muted-aa mt-4">
        Already have an account? <a href="/login" class="text-decoration-none">Sign in</a>
    </p>
</div>

{# Strip non-digits from any input flagged data-aa-digits-only — runs on
   every keystroke + paste so even pasting "(555) 123-4567" lands as
   "5551234567". Server-side PhoneNormalizer is still the source of truth. #}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-aa-digits-only]').forEach(function (el) {
            el.addEventListener('input', function () {
                var stripped = el.value.replace(/[^0-9]/g, '');
                if (stripped !== el.value) el.value = stripped;
            });
        });
    });
</script>
{% endblock %}
