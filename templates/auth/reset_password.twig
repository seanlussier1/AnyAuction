{% extends 'layout.twig' %}
{% block title %}{{ 'auth.reset.page_title'|t }} — AnyAuction{% endblock %}

{% block content %}
<div class="container py-5" style="max-width: 28rem;">
    <a href="/" class="d-flex align-items-center gap-2 text-decoration-none text-dark mb-4">
        <span class="aa-brand-badge"><i class="bi bi-hammer"></i></span>
        <span class="fs-5">AnyAuction</span>
    </a>

    <h1 class="h3 mb-1">{{ 'auth.reset.title'|t }}</h1>
    <p class="text-muted-aa mb-4">
        {{ 'auth.reset.subtitle'|t }}
    </p>

    <form method="post" action="/reset-password" class="d-flex flex-column gap-3">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">

        <div>
            <label class="form-label small text-muted-aa">{{ 'auth.reset.code'|t }}</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                <input type="text" name="code" class="form-control"
                       inputmode="numeric" pattern="\d{6}" maxlength="6"
                       autocomplete="one-time-code"
                       placeholder="123456" required autofocus>
            </div>
        </div>

        <div>
            <label class="form-label small text-muted-aa">{{ 'auth.reset.new_password'|t }}</label>
            <input type="password" name="password" class="form-control" required minlength="8">
            <div class="form-text">{{ 'auth.register.password_help'|t }}</div>
        </div>

        <div>
            <label class="form-label small text-muted-aa">{{ 'auth.reset.confirm'|t }}</label>
            <input type="password" name="password_confirm" class="form-control" required minlength="8">
        </div>

        <button type="submit" class="btn btn-primary py-2">
            {{ 'auth.reset.submit'|t }} <i class="bi bi-arrow-right ms-1"></i>
        </button>
    </form>

    <p class="text-center small text-muted-aa mt-4">
        <a href="/login" class="text-decoration-none">{{ 'auth.back_to_signin'|t }}</a>
    </p>
</div>
{% endblock %}
