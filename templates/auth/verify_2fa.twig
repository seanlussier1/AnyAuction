{% extends 'layout.twig' %}
{% block title %}Verify your code — AnyAuction{% endblock %}

{% block content %}
<div class="container py-5" style="max-width: 28rem;">
    <a href="/" class="d-flex align-items-center gap-2 text-decoration-none text-dark mb-4">
        <span class="aa-brand-badge"><i class="bi bi-hammer"></i></span>
        <span class="fs-5">AnyAuction</span>
    </a>

    <h1 class="h3 mb-1">Enter your code</h1>
    <p class="text-muted-aa mb-4">
        We texted a 6-digit code to your phone. It expires in 10 minutes.
    </p>

    <form method="post" action="/verify-2fa" class="d-flex flex-column gap-3">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">

        <div>
            <label class="form-label small text-muted-aa">6-digit code</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                <input type="text" name="code" class="form-control"
                       inputmode="numeric" pattern="\d{6}" maxlength="6"
                       autocomplete="one-time-code"
                       placeholder="123456" required autofocus>
            </div>
        </div>

        <button type="submit" class="btn btn-primary py-2">
            Verify and sign in <i class="bi bi-arrow-right ms-1"></i>
        </button>
    </form>

    <form method="post" action="/verify-2fa/resend" class="mt-3">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
        <button type="submit" class="btn btn-link text-decoration-none p-0 small">
            Didn't get it? Resend code
        </button>
    </form>

    <p class="text-center small text-muted-aa mt-4">
        <a href="/login" class="text-decoration-none">Back to sign in</a>
    </p>
</div>
{% endblock %}
