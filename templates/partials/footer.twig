<footer class="aa-footer">
    <div class="container py-5">
        <div class="row g-4">
            <div class="col-12 col-md-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="aa-brand-badge" style="background: rgba(255, 255, 255, 0.1);">
                        <i class="bi bi-hammer"></i>
                    </span>
                    <span class="fs-5 text-white">AnyAuction</span>
                </div>
                <p class="small text-white-50">{{ 'footer.tagline'|t }}</p>
            </div>

            <div class="col-6 col-md-3">
                <h4>{{ 'footer.col.marketplace'|t }}</h4>
                <a href="/browse">{{ 'footer.browse'|t }}</a>
                <a href="/sell">{{ 'footer.sell'|t }}</a>
                <a href="/browse">{{ 'footer.categories'|t }}</a>
            </div>

            <div class="col-6 col-md-2">
                <h4>{{ 'footer.col.support'|t }}</h4>
                <a href="#">{{ 'footer.help'|t }}</a>
                <a href="#">{{ 'footer.trust'|t }}</a>
                <a href="#">{{ 'footer.contact'|t }}</a>
            </div>

            <div class="col-6 col-md-3">
                <h4>{{ 'footer.col.legal'|t }}</h4>
                <a href="#">{{ 'footer.terms'|t }}</a>
                <a href="#">{{ 'footer.privacy'|t }}</a>
                <a href="#">{{ 'footer.cookies'|t }}</a>
            </div>
        </div>

        <hr class="border-light opacity-25 mt-4">

        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center small text-white-50 gap-2">
            <span>{{ 'footer.copyright'|t({ year: 'now'|date('Y') }) }}</span>
            <span><i class="bi bi-shield-lock me-1"></i>{{ 'footer.stripe'|t }}</span>
        </div>
    </div>
</footer>
