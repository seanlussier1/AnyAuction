{# Reviews summary + list. Expects { stats, reviews } in scope.
   stats: { rating, reviews, rating_average_round, rating_distribution }
   reviews: array of rows from Rating::reviewsForUser. #}
<div class="p-4 bg-warning-subtle rounded-lg-aa border border-warning-subtle mb-3 d-flex align-items-center gap-3">
    <div class="text-center" style="width: 100px;">
        <div class="fs-3 text-warning-emphasis mb-1">{{ stats.rating }}</div>
        <div class="text-warning">
            {% for i in 1..5 %}<i class="bi bi-star{{ i <= stats.rating_average_round ? '-fill' : '' }}"></i>{% endfor %}
        </div>
        <div class="small text-muted-aa">{{ stats.reviews }} review{{ stats.reviews == 1 ? '' : 's' }}</div>
    </div>
    <div class="flex-grow-1 small">
        {% set total = stats.reviews > 0 ? stats.reviews : 1 %}
        {% for s in [5, 4, 3, 2, 1] %}
            {% set bucket = stats.rating_distribution[s] ?? 0 %}
            {% set pct = (bucket / total) * 100 %}
            <div class="d-flex align-items-center gap-2 mb-1">
                <span style="width: 0.75rem;">{{ s }}</span>
                <i class="bi bi-star-fill text-warning" style="font-size: 0.7rem;"></i>
                <div class="progress flex-grow-1" style="height: 6px;">
                    <div class="progress-bar bg-warning" style="width: {{ pct }}%;"></div>
                </div>
                <span class="text-muted-aa" style="width: 1rem;">{{ bucket }}</span>
            </div>
        {% endfor %}
    </div>
</div>

{% if reviews|length == 0 %}
    <p class="text-center text-muted-aa py-3">No reviews yet.</p>
{% else %}
    <div class="d-flex flex-column gap-3">
        {% for r in reviews %}
            <div class="border rounded-lg-aa p-3">
                <div class="d-flex align-items-center gap-2 mb-1">
                    {% if r.reviewer_profile_picture %}
                        <img src="{{ r.reviewer_profile_picture }}" class="rounded-circle" width="32" height="32" alt="">
                    {% else %}
                        <span class="aa-brand-badge d-inline-flex align-items-center justify-content-center" style="width:32px;height:32px;"><i class="bi bi-person"></i></span>
                    {% endif %}
                    <div class="flex-grow-1 min-w-0">
                        <div class="fw-medium small">
                            <a href="/users/{{ r.rater_id }}" class="text-decoration-none text-dark">{{ r.reviewer_first_name }} {{ r.reviewer_last_name }}</a>
                            {% if r.direction == 'seller_to_buyer' %}
                                <span class="badge bg-secondary-subtle text-secondary-emphasis ms-1" style="font-size: .65rem;">as seller</span>
                            {% else %}
                                <span class="badge bg-secondary-subtle text-secondary-emphasis ms-1" style="font-size: .65rem;">as buyer</span>
                            {% endif %}
                        </div>
                        <div class="small text-muted-aa">on <a href="/auction/{{ r.item_id }}">{{ r.item_title }}</a> · {{ r.created_at|date('M j, Y') }}</div>
                    </div>
                    <div class="text-warning small flex-shrink-0">
                        {% for i in 1..5 %}<i class="bi bi-star{{ i <= r.score ? '-fill' : '' }}"></i>{% endfor %}
                    </div>
                </div>
                {% if r.comment %}<p class="mb-0 small">{{ r.comment }}</p>{% endif %}
            </div>
        {% endfor %}
    </div>
{% endif %}
