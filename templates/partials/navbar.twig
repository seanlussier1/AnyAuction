<nav class="aa-navbar sticky-top py-2">
    <div class="container d-flex align-items-center gap-3">
        <a href="/" class="d-flex align-items-center gap-2 text-decoration-none text-dark flex-shrink-0">
            <span class="aa-brand-badge"><i class="bi bi-hammer"></i></span>
            <span class="d-none d-sm-inline fs-5">AnyAuction</span>
        </a>

        <form action="/browse" method="get" class="flex-grow-1 d-none d-md-block position-relative" style="max-width: 32rem;" autocomplete="off">
            <i class="bi bi-search position-absolute top-50 translate-middle-y ms-3 text-muted-aa"></i>
            <input type="search" id="aa-search-input" name="q" class="aa-search" placeholder="Search auctions…" value="{{ search_query|default('') }}">
            <div id="aa-search-dropdown" class="aa-search-dropdown" hidden></div>
        </form>

        <div class="ms-auto d-flex align-items-center gap-2">
            <a href="/browse" class="btn btn-sm btn-link text-dark text-decoration-none d-none d-md-inline">Browse</a>
            <a href="/sell"   class="btn btn-sm btn-link text-dark text-decoration-none d-none d-md-inline">Sell</a>

            {% if current_user %}
                <a href="/watchlist" class="btn btn-sm btn-link text-dark position-relative" aria-label="Watchlist">
                    <i class="bi bi-heart fs-5"></i>
                </a>
                <a href="/profile#tab-notifications" class="btn btn-sm btn-link text-dark position-relative" aria-label="Notifications">
                    <i class="bi bi-bell fs-5"></i>
                    {% if unread_notifications|default(0) > 0 %}
                        <span class="aa-bell-badge position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark" style="font-size: 0.65rem; padding: 0.25rem 0.4rem;">
                            {{ unread_notifications > 9 ? '9+' : unread_notifications }}
                        </span>
                    {% endif %}
                </a>

                <div class="dropdown">
                    <button class="btn btn-sm d-flex align-items-center gap-2 border-0" data-bs-toggle="dropdown" aria-expanded="false">
                        {% if current_user.profile_picture %}
                            <img src="{{ current_user.profile_picture }}" alt="" class="rounded-circle" width="28" height="28">
                        {% else %}
                            <span class="aa-brand-badge" style="width: 28px; height: 28px;">
                                <i class="bi bi-person"></i>
                            </span>
                        {% endif %}
                        <i class="bi bi-chevron-down small"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow rounded-lg-aa">
                        <li class="px-3 py-2 border-bottom">
                            <div class="small">{{ current_user.first_name }} {{ current_user.last_name }}</div>
                            <div class="text-muted-aa small">@{{ current_user.username }}</div>
                        </li>
                        <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                        <li><a class="dropdown-item" href="/watchlist"><i class="bi bi-heart me-2"></i>Watchlist</a></li>
                        {% if current_user.role == 'admin' %}
                            <li><a class="dropdown-item" href="/admin"><i class="bi bi-shield-lock me-2"></i>Admin Panel</a></li>
                        {% endif %}
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form action="/logout" method="post" class="m-0">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            {% else %}
                <a href="/login" class="btn btn-sm btn-link text-dark text-decoration-none">Log In</a>
                <a href="/register" class="btn btn-sm btn-amber px-3">Sign Up</a>
            {% endif %}
        </div>
    </div>
</nav>
{# search-suggest.js is loaded globally from layout.twig — it short-circuits
   when the navbar input/dropdown ids aren't on the page. #}
