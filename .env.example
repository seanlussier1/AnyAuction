APP_ENV=dev
DISPLAY_ERROR_DETAILS=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=anyauction
DB_USER=root
DB_PASS=

# Stripe (test mode). Both keys live at https://dashboard.stripe.com/test/apikeys.
# Never commit real secrets — the .env file itself is gitignored.
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
APP_BASE_URL=http://localhost:8000

# Twilio (creds at https://console.twilio.com). Phone is E.164 with leading +.
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+15551234567
